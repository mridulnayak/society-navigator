# Node / Vite / Frontend .gitignore

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules/

# Build outputs
dist/
dist-ssr/
build/
out/
.vite/
.parcel-cache/
.cache/
coverage/
*.tgz

# Environment files (explicitly included per request)
.env
.env.*
.env.local
.env.*.local
.secrets.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
desktop.ini

# OS or swap files
*.swp
*.swo

# Misc
pids
*.pid
*.seed
*.pid.lock

# TypeScript
*.tsbuildinfo

# Optional npm cache folder
.npm

# End of frontend .gitignore
